# Copy to .env next to compose.yaml on the VPS.

# Scraper service (scraper/server.py) base URL.
# Default deployment runs the scraper container on the VPS itself, reachable on
# the docker0 gateway:
SCRAPER_URL=http://172.17.0.1:8044
# Fallback if the VPS IP ever gets blocked: run scraper/ on a residential machine
# and use its raw tailnet IP here (MagicDNS names don't resolve inside containers).
# Leave empty to disable scraping (cache-only server).
